# Public canonical URL — used by sitemap, robots, OG metadata
NEXT_PUBLIC_SITE_URL=https://fragosnexus.ai

# ── Contact form (Resend) ──────────────────────────────────────
# Get a key at https://resend.com (free tier available).
# Without this key the form still works: it accepts submissions
# and logs the lead server-side instead of emailing it.
RESEND_API_KEY=
# Where leads are delivered:
CONTACT_TO_EMAIL=hello@fragosnexus.ai
# Verified sender. Use onboarding@resend.dev for quick tests,
# or a verified domain address in production.
CONTACT_FROM_EMAIL=Nexus <onboarding@resend.dev>
